<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#FFF8EC"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:strokeColor="#E7D8C4"
    app:strokeWidth="1dp"
    tools:ignore="HardcodedText,TouchTargetSizeCheck">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imgPlato"
            android:layout_width="95dp"
            android:layout_height="95dp"
            android:background="#FDF2E3"
            android:padding="2dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvNombrePlato"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="Nombre del Plato"
            android:textColor="#3E2723"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgPlato"
            app:layout_constraintEnd_toStartOf="@id/tvPrecioPlato"
            app:layout_constraintTop_toTopOf="@id/imgPlato" />

        <TextView
            android:id="@+id/tvPrecioPlato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S/ 0.00"
            android:textColor="#C8401A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvNombrePlato" />

        <TextView
            android:id="@+id/tvDescPlato"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:text="Descripción del plato"
            android:textColor="#6D4C41"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/imgPlato"
            app:layout_constraintEnd_toStartOf="@id/btnAgregar"
            app:layout_constraintTop_toBottomOf="@id/tvNombrePlato" />

        <Button
            android:id="@+id/btnAgregar"
            android:layout_width="110dp"
            android:layout_height="42dp"
            android:backgroundTint="#C8401A"
            android:elevation="2dp"
            android:text="Agregar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imgPlato"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>