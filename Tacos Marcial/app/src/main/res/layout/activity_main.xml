<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF9E3"
    android:fillViewport="true"
    tools:ignore="HardcodedText,ContentDescription,Typos,UselessParent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#A6211F"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="30dp"
            android:paddingEnd="20dp"
            android:paddingBottom="30dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_circle_white"
                android:elevation="4dp"
                android:padding="10dp"
                android:src="@drawable/ic_taco_placeholder"
                android:contentDescription="Logo Tacos Marcial" />

            <TextView
                android:id="@+id/tvRestaurantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tacos Marcial"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Restaurante fusión 🇵🇪/🇲🇽"
                android:textColor="#FFEB3B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_badge_closed"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="● Cerrado ahora"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF9E3"
            android:elevation="2dp"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnPedir"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="#C8401A"
                android:text="Pedir ahora"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF9E3"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenid@s a Tacos Marcial"
                android:textColor="#A6211F"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWelcomeDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="Ordena unos deliciosos tacos, enchiladas, broasters, hamburguesas y mucho más. ¿Qué esperas?"
                android:textColor="#5D4037"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="#F9F2D3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF9E3"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/btnParaLlevar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_service_selected"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_takeaway"
                    android:contentDescription="Para llevar"
                    app:tint="#C8401A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Para Recojo en Tienda"
                    android:textColor="#C8401A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnADomicilio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_service_default"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_delivery"
                    android:contentDescription="A domicilio"
                    app:tint="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="A domicilio"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="#F9F2D3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF9E3"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="Redes sociales"
                android:textColor="#A6211F"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnWhatsApp"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_social_whatsapp"
                    android:elevation="2dp"
                    android:padding="11dp"
                    android:src="@drawable/ic_whatsapp"
                    android:contentDescription="WhatsApp"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:id="@+id/btnInstagram"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_social_instagram"
                    android:elevation="2dp"
                    android:padding="11dp"
                    android:src="@drawable/ic_instagram"
                    android:contentDescription="Instagram"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:id="@+id/btnFacebook"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_social_facebook"
                    android:elevation="2dp"
                    android:padding="11dp"
                    android:src="@drawable/ic_facebook"
                    android:contentDescription="Facebook"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:id="@+id/btnTikTok"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_social_tiktok"
                    android:elevation="2dp"
                    android:padding="11dp"
                    android:src="@drawable/ic_tiktok"
                    android:contentDescription="TikTok"
                    app:tint="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="#F9F2D3" />

        <LinearLayout
            android:id="@+id/btnMenuDigital"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="Menú"
                android:src="@drawable/ic_menu_book"
                app:tint="#C8401A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Menú digital"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription=""
                android:src="@drawable/ic_chevron_right"
                app:tint="#BBBBBB" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="#E0D5B0" />

        <LinearLayout
            android:id="@+id/btnHorarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="Horarios"
                android:src="@drawable/ic_access_time"
                app:tint="#C8401A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Tipos de servicio y horarios"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription=""
                android:src="@drawable/ic_chevron_right"
                app:tint="#BBBBBB" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="#E0D5B0" />

        <LinearLayout
            android:id="@+id/btnHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_menu_book"
                app:tint="#C8401A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Historial de Pedidos"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="#BBBBBB" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:background="#F9F2D3" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#333333"
            android:text="Cerrar sesión"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="28dp"
            android:text="🌮 Tacos Marcial"
            android:textColor="#A6211F"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>